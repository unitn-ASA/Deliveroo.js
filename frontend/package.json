{
  "name": "@unitn-asa/deliveroo-js-webapp",
  "version": "2.3.0",
  "private": true,
  "type": "module",
  "module": "es2022",
  "repository": {
    "type": "git",
    "url": "https://github.com/unitn-ASA/Deliveroo.js.git"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "npm install --include=dev",
    "build": "vite build",
    "preview": "vite preview",
    "docs": "typedoc",
    "postbuild": "jq '. | del(.dependencies, .devDependencies, .scripts, .private) | .name=\"@unitn-asa/deliveroo-js-webapp-dist\" | .private=false' package.json > dist/package.json; cp README.md dist/"
  },
  "dependencies": {
    "@unitn-asa/deliveroo-js-assets": "*",
    "@unitn-asa/deliveroo-js-sdk": "*",
    "jwt-decode": "^4.0.0",
    "node-fetch": "^3.3.2",
    "socket.io-client": "^4.7.2",
    "three": "^0.151.3",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.13",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typedoc": "^0.28.17",
    "vite": "^6.2.2",
    "vite-plugin-commonjs": "^0.10.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.6.1"
  },
  "engines": {
    "node": "22.x"
  }
}

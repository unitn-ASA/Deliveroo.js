{
  "compilerOptions": {
      "module": "es2022",
      "target": "es2022",
      "moduleResolution": "node",
    "sourceMap": true,
    "allowJs": true,
    "checkJs": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "exclude": [
    "node_modules",
      "**/node_modules/*",
      "dist"
    ]
}
